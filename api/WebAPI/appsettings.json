{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
            "LogLevel": {
                "Default": "Debug",
                "Microsoft": "Debug",
                "Microsoft.Hosting.Lifetime": "Debug"
            },
            "FormatterName": "simple",
            "FormatterOptions": {
                "SingleLine": true,
                "IncludeScopes": false,
                "TimestampFormat": "HH:mm:ss ",
                "UseUtcTimestamp": true,
                "JsonWriterOptions": {
                    "Indented": true
                }
            }
        }
  },
  "Kestrel": {
    "Certificates": {
      "Default": {
        "Path": "../../.devcontainer/devcert.pfx",
        "Password": "mycertpassword"
      }
    }
  },
  "AllowedHosts": "*",
